# =============================================================================
# Tempo Docker - Default Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your deployment.
# Variables ending in _TAG, _REPO, or _DOCKERFILE are "build targets"
# that get reset during updates when --refresh-targets is used.
# =============================================================================

# Environment version - increment when adding/renaming variables
ENV_VERSION=5

# Compose files to use (colon-separated)
# Add :ext-network.yml for Traefik/Prometheus integration
# Add :rpc-shared.yml to expose RPC ports locally
COMPOSE_FILE=tempo.yml

# Project name - used for container naming and Docker volume prefixes
PROJECT_NAME=tempo

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================

# Tempo network (mainnet only currently — see https://docs.tempo.xyz/guide/node)
NETWORK=mainnet
CHAIN_ID=4217

# =============================================================================
# DOCKER IMAGES
# =============================================================================

# Tempo Reth-based binary image — pinned to T3 Network Upgrade
# Releases: https://github.com/tempoxyz/tempo/releases
NODE_DOCKER_REPO=ghcr.io/tempoxyz/tempo
NODE_DOCKER_TAG=1.6.0

# =============================================================================
# DATA STORAGE
# =============================================================================

# Docker volume for node state.
# Mounted at /root/.local/share/reth/tempo inside the container.
# Tempo RPC nodes run archive mode by default. Upstream guidance is 1000 GB
# minimum / 2000 GB recommended NVMe for production RPC nodes.
DATA_VOLUME=tempo-data

# Set true only if DATA_VOLUME is already initialized and the automatic
# pre-start snapshot download should be skipped.
SKIP_SNAPSHOT_BOOTSTRAP=false

# =============================================================================
# PORTS
# =============================================================================

# RPC HTTP port (in-container 8545)
RPC_PORT=8545

# RPC WebSocket port (in-container 8546)
WS_PORT=8546

# Reth metrics port (in-container 9000)
METRICS_PORT=9000

# P2P port (Reth default 30303 — change if the host has a conflict)
P2P_PORT=30303

# Tempo bootnodes. First boot needs explicit peers because follow mode supplies
# consensus payloads but does not backfill execution data by itself.
BOOTNODES=enode://b8c911b351614b71d027fcec98957be800cdc5e290b616d7f034a89c07d2be480fb9f11700cf7fc77073119b7d3d0855f697ebd4118fb34a35bd53ac58503122@148.113.220.159:30008,enode://944d8afe14b222ccf26e328bedc10d1db94d756d836b956d1daa5e681f8b29ae48973528af1362110ce61e4d338d758a7e5bba19a66d289a7d536fba795403a1@15.204.106.68:30017,enode://135666c3e82f051e803ae39d401c62329d0bd1b7c868bf9a9154b0aaca0fa9fe3a474b357ef09ff5238d7c6d56be8c3c7533feff277bd839b506e98433418fa5@40.160.22.6:30011,enode://34b106ae5eddcaf9943987a9d38bb45dc2a64bbac996f34ddecd863217af567273102b4b7010e7cf516151c3903927a18abb1fafe32bb999d752fca064158e05@40.160.64.50:30006,enode://048954f10e776c4c31269b97dfbbe52be9dbce48278a02f67cd7a6eec805c1114c25c27e3e9bfabfb8117d134d89190888bb952b73a29f7c8430552a5192ec04@15.204.106.73:30015

# =============================================================================
# LOGGING
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# =============================================================================
# TRAEFIK/PROMETHEUS INTEGRATION
# =============================================================================

# External Docker network name for reverse proxy / monitoring
DOCKER_EXT_NETWORK=traefik_default

# Secure web proxy hostnames (used with Traefik labels)
DOMAIN=example.com
RPC_HOST=tempo
RPC_LB=tempo-lb
WS_HOST=tempows
WS_LB=tempows-lb

# =============================================================================
# VERSION PINNING
# =============================================================================

# Pin this repo to a specific git tag (leave empty for latest main)
SCRIPT_TAG=
